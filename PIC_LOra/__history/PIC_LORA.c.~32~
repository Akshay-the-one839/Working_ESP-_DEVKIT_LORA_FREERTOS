// ============================================================
//  save_valve_states_to_eeprom()
//
//  Writes the current state of all 8 valves AND their vanoflg
//  values to EEPROM so they survive a power cycle.
//
//  Called once after every successful packet parse + GPIO change.
//  NOT called every loop iteration — only on change — so EEPROM
//  endurance (100 000 write cycles) is not an issue.
// ============================================================
void save_valve_states_to_eeprom(void)
{
    // Write magic marker so boot code knows EEPROM is valid
    write_eeprom(EEPROM_MAGIC_ADDR, EEPROM_MAGIC_VALUE);

    // States ('0' or '1' as raw char)
    write_eeprom(EEPROM_STATE_BASE + 0, (int8)state1);
    write_eeprom(EEPROM_STATE_BASE + 1, (int8)state2);
    write_eeprom(EEPROM_STATE_BASE + 2, (int8)state3);
    write_eeprom(EEPROM_STATE_BASE + 3, (int8)state4);
    write_eeprom(EEPROM_STATE_BASE + 4, (int8)state5);
    write_eeprom(EEPROM_STATE_BASE + 5, (int8)state6);
    write_eeprom(EEPROM_STATE_BASE + 6, (int8)state7);
    write_eeprom(EEPROM_STATE_BASE + 7, (int8)state8);

    // vanoflg (0 or 1)
    write_eeprom(EEPROM_FLAG_BASE + 0, (int8)vanoflg1);
    write_eeprom(EEPROM_FLAG_BASE + 1, (int8)vanoflg2);
    write_eeprom(EEPROM_FLAG_BASE + 2, (int8)vanoflg3);
    write_eeprom(EEPROM_FLAG_BASE + 3, (int8)vanoflg4);
    write_eeprom(EEPROM_FLAG_BASE + 4, (int8)vanoflg5);
    write_eeprom(EEPROM_FLAG_BASE + 5, (int8)vanoflg6);
    write_eeprom(EEPROM_FLAG_BASE + 6, (int8)vanoflg7);
    write_eeprom(EEPROM_FLAG_BASE + 7, (int8)vanoflg8);

    printf("[EEPROM] States saved\r\n");
}

// ============================================================
//  load_valve_states_from_eeprom()
//
//  Called once at boot.  Reads back states and flags, then
//  drives the GPIO pins to match.
//  If magic byte is missing (first-ever boot / erased chip),
//  all valves default to OFF — safe behaviour.
// ============================================================
void load_valve_states_from_eeprom(void)
{
    int8 magic = read_eeprom(EEPROM_MAGIC_ADDR);

    if (magic != EEPROM_MAGIC_VALUE)
    {
        // First boot or erased chip — start with everything OFF
        printf("[EEPROM] No saved state (magic=0x%02X) — defaulting OFF\r\n", magic);

        state1='0'; state2='0'; state3='0'; state4='0';
        state5='0'; state6='0'; state7='0'; state8='0';
        vanoflg1=0; vanoflg2=0; vanoflg3=0; vanoflg4=0;
        vanoflg5=0; vanoflg6=0; vanoflg7=0; vanoflg8=0;

        output_low(V1); output_low(V2);
        output_low(V3); output_low(V4);
        output_low(V5); output_low(V6);
        output_low(V7); output_low(V8);

        // Write magic + all-OFF so next boot is clean
        save_valve_states_to_eeprom();
        return;
    }

    // Valid saved state — restore it
    state1 = (char)read_eeprom(EEPROM_STATE_BASE + 0);
    state2 = (char)read_eeprom(EEPROM_STATE_BASE + 1);
    state3 = (char)read_eeprom(EEPROM_STATE_BASE + 2);
    state4 = (char)read_eeprom(EEPROM_STATE_BASE + 3);
    state5 = (char)read_eeprom(EEPROM_STATE_BASE + 4);
    state6 = (char)read_eeprom(EEPROM_STATE_BASE + 5);
    state7 = (char)read_eeprom(EEPROM_STATE_BASE + 6);
    state8 = (char)read_eeprom(EEPROM_STATE_BASE + 7);

    vanoflg1 = (int1)read_eeprom(EEPROM_FLAG_BASE + 0);
    vanoflg2 = (int1)read_eeprom(EEPROM_FLAG_BASE + 1);
    vanoflg3 = (int1)read_eeprom(EEPROM_FLAG_BASE + 2);
    vanoflg4 = (int1)read_eeprom(EEPROM_FLAG_BASE + 3);
    vanoflg5 = (int1)read_eeprom(EEPROM_FLAG_BASE + 4);
    vanoflg6 = (int1)read_eeprom(EEPROM_FLAG_BASE + 5);
    vanoflg7 = (int1)read_eeprom(EEPROM_FLAG_BASE + 6);
    vanoflg8 = (int1)read_eeprom(EEPROM_FLAG_BASE + 7);

    // Re-drive GPIO to match saved state
    if (state1 == '1') output_high(V1); else output_low(V1);
    if (state2 == '1') output_high(V2); else output_low(V2);
    if (state3 == '1') output_high(V3); else output_low(V3);
    if (state4 == '1') output_high(V4); else output_low(V4);
    if (state5 == '1') output_high(V5); else output_low(V5);
    if (state6 == '1') output_high(V6); else output_low(V6);
    if (state7 == '1') output_high(V7); else output_low(V7);
    if (state8 == '1') output_high(V8); else output_low(V8);

    printf("[EEPROM] States restored: %c%c%c%c%c%c%c%c\r\n",
           state1,state2,state3,state4,state5,state6,state7,state8);
}

// ============================================================
//  Timer1 ISR — ~50 ms tick, counts to 1 s
//  Decrements per-valve timers and wall clock.
// ============================================================
void setup_timer1_for_1s_interrupt() {
    setup_timer_1(T1_INTERNAL | T1_DIV_BY_8);
    set_timer1(34286);
    enable_interrupts(INT_TIMER1);
}

#INT_TIMER1
void timer1_isr()
{
    overflow_count++;
    set_timer1(34286);

    if (overflow_count >= 20)   // 20 × ~50 ms = 1 second
    {
        overflow_count = 0;
        sec++;

        // Decrement per-valve timers
        if (v1_timer > 0) v1_timer--;
        if (v2_timer > 0) v2_timer--;
        if (v3_timer > 0) v3_timer--;
        if (v4_timer > 0) v4_timer--;
        if (v5_timer > 0) v5_timer--;
        if (v6_timer > 0) v6_timer--;
        if (v7_timer > 0) v7_timer--;
        if (v8_timer > 0) v8_timer--;

        // Wall clock
        if (sec >= 59)
        {
            sec = 0;
            min++;
            bwminv1++; if (bwminv1 >= 11) bwminv1 = 0;
            bwminv2++; if (bwminv2 >= 11) bwminv2 = 0;

            // Save wall clock to EEPROM (addresses 40/41 — same as original)
            write_eeprom(eeprom_base_address + 40, hr);
            write_eeprom(eeprom_base_address + 41, min);

            if (min >= 59) { min = 0; hr++; }
            if (hr  >= 24)   hr = 0;
        }
    }
}

// ??? EEPROM helpers (kept from original) ?????????????????
void store_byte(unsigned int16 address, unsigned char value) {
    if (address < 256) write_eeprom(address, value);
}
unsigned char retrieve_byte(unsigned int16 address) {
    if (address < 256) return read_eeprom(address);
    return 0;
}

// ============================================================
//  RDA ISR — collect one packet.
//  Filters MY_ID as first byte — discards other slaves' traffic.
//  No delay_ms() allowed here.
// ============================================================
#int_RDA
void RDA_isr(void)
{
    if (OERR) { CREN = 0; CREN = 1; return; }
    if (FERR) { getc(COM_1); return; }

    char first = getc(COM_1);
    if (first != MY_ID) return;

    int8 idx = 0;
    char x;

    while (idx < 55)
    {
        x = getc(COM_1);
        RxBuffer[idx] = x;
        idx++;
        if (x == '*' && idx > 30) break;
    }

    RxBuffer[idx] = '\0';
    RX_Command_Ready = 1;
}

// ============================================================
//  txvalve — send ACK frame back to master
// ============================================================
void txvalve()
{
    int8 k;
    for (k = 0; k < 5; k++)
    {
        output_high(SIGLED);
        fprintf(COM_1, "$");
        fprintf(COM_1, "%c,", MY_ID);
        fprintf(COM_1, "1,%c,", state1);
        fprintf(COM_1, "2,%c,", state2);
        fprintf(COM_1, "3,%c,", state3);
        fprintf(COM_1, "4,%c,", state4);
        fprintf(COM_1, "5,%c,", state5);
        fprintf(COM_1, "6,%c,", state6);
        fprintf(COM_1, "7,%c,", state7);
        fprintf(COM_1, "8,%c,", state8);
        fprintf(COM_1, "\n");
        delay_ms(100);
    }
    output_low(SIGLED);
    txflg = 0;
}

// ============================================================
//  parse_packet — tokenise RxBuffer into vnoN / stateN
// ============================================================
void parse_packet(void)
{
    char *ptr;
    int   index = 0;
    char  sep[] = "*";

    ptr = strtok(RxBuffer, sep);

    while (ptr != NULL)
    {
        switch (index)
        {
            case  0: vno1   = ptr[0]; break;
            case  1: state1 = ptr[0]; break;
            case  2: vno2   = ptr[0]; break;
            case  3: state2 = ptr[0]; break;
            case  4: vno3   = ptr[0]; break;
            case  5: state3 = ptr[0]; break;
            case  6: vno4   = ptr[0]; break;
            case  7: state4 = ptr[0]; break;
            case  8: vno5   = ptr[0]; break;
            case  9: state5 = ptr[0]; break;
            case 10: vno6   = ptr[0]; break;
            case 11: state6 = ptr[0]; break;
            case 12: vno7   = ptr[0]; break;
            case 13: state7 = ptr[0]; break;
            case 14: vno8   = ptr[0]; break;
            case 15: state8 = ptr[0]; break;
            case 16: strcpy(TimeBuffer, ptr); break;
        }
        ptr = strtok(NULL, sep);
        index++;
    }

    printf("\r\n=== Parsed Packet ===\r\n");
    printf("SlaveID: %c\r\n", MY_ID);
    printf("Time   : %s\r\n", TimeBuffer);
    printf("V1:%c S:%c  V2:%c S:%c  V3:%c S:%c  V4:%c S:%c\r\n",
           vno1,state1, vno2,state2, vno3,state3, vno4,state4);
    printf("V5:%c S:%c  V6:%c S:%c  V7:%c S:%c  V8:%c S:%c\r\n",
           vno5,state5, vno6,state6, vno7,state7, vno8,state8);
    printf("=====================\r\n");
}

