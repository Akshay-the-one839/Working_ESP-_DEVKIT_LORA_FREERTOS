// ============================================================
//  EEPROM ADDRESS MAP
//  PIC18F25K22 has 256 bytes of data EEPROM (0x00 to 0xFF)
//
//  Address  |  Size  |  Contents
//  ---------+--------+------------------------------------
//  0x00     |  1 B   |  Magic marker (0xA5) — written at
//           |        |  first boot. If not 0xA5, EEPROM is
//           |        |  uninitialised ? treat all valves OFF.
//  0x01     |  1 B   |  Valve 1 state  (0x00 = OFF, 0x01 = ON)
//  0x02     |  1 B   |  Valve 2 state
//  0x03     |  1 B   |  Valve 3 state
//  0x04     |  1 B   |  Valve 4 state
//  0x05     |  1 B   |  Valve 5 state
//  0x06     |  1 B   |  Valve 6 state
//  0x07     |  1 B   |  Valve 7 state
//  0x08     |  1 B   |  Valve 8 state
//  0x09     |  1 B   |  vanoflg1 (energise flag valve 1)
//  0x0A     |  1 B   |  vanoflg2
//  0x0B     |  1 B   |  vanoflg3
//  0x0C     |  1 B   |  vanoflg4
//  0x0D     |  1 B   |  vanoflg5
//  0x0E     |  1 B   |  vanoflg6
//  0x0F     |  1 B   |  vanoflg7
//  0x10     |  1 B   |  vanoflg8
//  0x28     |  1 B   |  hr  (wall clock — same as original code)
//  0x29     |  1 B   |  min (wall clock)
//  0x2A..FF |        |  RESERVED / unused
//
//  NOTE: addresses 0x28/0x29 (40/41 decimal) are kept identical
//  to the original code that used write_eeprom(40, hr) etc.
// ============================================================
#define EEPROM_MAGIC_ADDR    0x00   // 1 byte  — init marker
#define EEPROM_MAGIC_VALUE   0xA5   // value that means "initialised"
#define EEPROM_STATE_BASE    0x01   // 8 bytes — valve states   (0x01..0x08)
#define EEPROM_FLAG_BASE     0x09   // 8 bytes — vanoflg values (0x09..0x10)
// addresses 0x28 (40) and 0x29 (41) are hr/min — unchanged from original

// ??? UART register bits ??????????????????????????????????
