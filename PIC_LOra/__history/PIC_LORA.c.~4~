// --- CHANGED: processCommand — parse $M*A*...# format ------------------------
// Old: fixed index stepping through comma-separated buffer
// New: split by '*', extract tokens at confirmed positions
//
// Token positions after split:
// [0]=$M [1]=A [2]=vno1 [3]=s1 [4]=unused [5]=timer
// [6]=vno2 [7]=s2 [8]=vno3 [9]=s3 ... [18]=vno8 [19]=s8
void processCommand() {
    char buf[RX_BUF_SIZE];
    char *tokens[22];
    int8  tcount = 0;
    char *tok;
    int8  i;

    // Zone A only
    if (RxBuffer[3] != 'A') return;

    // Null-terminate at '#'
    char *ep = strchr(RxBuffer, '#');
    if (ep == NULL) return;
    *ep = '\0';

    // Copy buffer (strtok modifies it)
    strncpy(buf, RxBuffer, RX_BUF_SIZE - 1);
    buf[RX_BUF_SIZE - 1] = '\0';

    // Tokenize by '*'
    tok = strtok(buf, "*");
    while (tok != NULL && tcount < 22) {
        tokens[tcount++] = tok;
        tok = strtok(NULL, "*");
    }

    if (tcount < 20) return;

    // Extract valve numbers and states — same variable names as original PIC
    vno1 = tokens[2][0];  state1 = tokens[3][0];
    vno2 = tokens[6][0];  state2 = tokens[7][0];
    vno3 = tokens[8][0];  state3 = tokens[9][0];
    vno4 = tokens[10][0]; state4 = tokens[11][0];
    vno5 = tokens[12][0]; state5 = tokens[13][0];
    vno6 = tokens[14][0]; state6 = tokens[15][0];
    vno7 = tokens[16][0]; state7 = tokens[17][0];
    vno8 = tokens[18][0]; state8 = tokens[19][0];

    // -- Everything below is UNCHANGED from original PIC code -----------------

    // V1
    if (vno1=='1' && vanoflg1==0 && state1=='1') { output_high(V1); vanoflg1=1; }
    if (vno1=='1' && vanoflg1==1 && state1=='0') { output_low(V1);  vanoflg1=0; }

    // V2
    if (vno2=='2' && vanoflg2==0 && state2=='1') { output_high(V2); vanoflg2=1; }
    if (vno2=='2' && vanoflg2==1 && state2=='0') { output_low(V2);  vanoflg2=0; }

    // V3
    if (vno3=='3' && vanoflg3==0 && state3=='1') { output_high(V3); vanoflg3=1; delay_ms(2000); }
    if (vno3=='3' && vanoflg3==1 && state3=='0') { output_low(V3);  vanoflg3=0; }

    // V4
    if (vno4=='4' && vanoflg4==0 && state4=='1') { output_high(V4); vanoflg4=1; delay_ms(2000); }
    if (vno4=='4' && vanoflg4==1 && state4=='0') { output_low(V4);  vanoflg4=0; }

    // V5
    if (vno5=='5' && vanoflg5==0 && state5=='1') { output_high(V5); vanoflg5=1; delay_ms(2000); }
    if (vno5=='5' && vanoflg5==1 && state5=='0') { output_low(V5);  vanoflg5=0; }

    // V6
    if (vno6=='6' && vanoflg6==0 && state6=='1') { output_high(V6); vanoflg6=1; delay_ms(2000); }
    if (vno6=='6' && vanoflg6==1 && state6=='0') { output_low(V6);  vanoflg6=0; }

    // V7
    if (vno7=='7' && vanoflg7==0 && state7=='1') { output_high(V7); vanoflg7=1; delay_ms(2000); }
    if (vno7=='7' && vanoflg7==1 && state7=='0') { output_low(V7);  vanoflg7=0; }

    // V8
    if (vno8=='8' && vanoflg8==0 && state8=='1') { output_high(V8); vanoflg8=1; delay_ms(2000); }
    if (vno8=='8' && vanoflg8==1 && state8=='0') { output_low(V8);  vanoflg8=0; }
}

