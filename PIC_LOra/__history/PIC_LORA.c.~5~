// RxBuffer increased for new packet format
#define RX_BUF_SIZE 96
char RxBuffer[RX_BUF_SIZE];
int8 RxIndex = 0;

int1 RX_Command_Ready = 0;

char state1='0', state2='0', state3='0', state4='0';
char state5='0', state6='0', state7='0', state8='0';

char vno1, vno2, vno3, vno4, vno5, vno6, vno7, vno8;
char bw[2];

int1 vanoflg1=0, vanoflg2=0, vanoflg3=0, vanoflg4=0;
int1 vanoflg5=0, vanoflg6=0, vanoflg7=0, vanoflg8=0;

int1 txflg=0;
int1 txflgg=0;

int8 overflow_count=0;
int8 sec=0, min=0, hr=0;
int8 bwmin=0, bwminv1=0, bwminv2=0;

unsigned int16 eeprom_base_address=0;

// --- Timer1 (unchanged) -------------------------------------------------------
void setup_timer1_for_1s_interrupt() {
    setup_timer_1(T1_INTERNAL | T1_DIV_BY_8);
    set_timer1(34286);
    enable_interrupts(INT_TIMER1);
}

#INT_TIMER1
void timer1_isr() {
    overflow_count++;
    set_timer1(34286);
    if (overflow_count >= 20) {
        sec++;
        overflow_count = 0;
        if (sec >= 59) {
            sec = 0; min++;
            bwminv1++; if (bwminv1 >= 11) bwminv1 = 0;
            bwminv2++; if (bwminv2 >= 11) bwminv2 = 0;
            write_eeprom(eeprom_base_address + 40, hr);
            write_eeprom(eeprom_base_address + 41, min);
            if (min >= 59) { min = 0; hr++; }
            if (hr  >= 24) hr = 0;
        }
    }
}

void store_byte(unsigned int16 address, unsigned char value) {
    if (address < 256) write_eeprom(address, value);
}

unsigned char retrieve_byte(unsigned int16 address) {
    if (address < 256) return read_eeprom(address);
    return 0;
}

// --- CHANGED: RDA ISR — collect until '#' ------------------------------------
#int_RDA
void RDA_isr(void) {
    char c;
    c = getc(COM_1);

    if (c == '$') {
        int8 i;
        for (i = 0; i < RX_BUF_SIZE; i++) RxBuffer[i] = 0;
        RxIndex = 0;
        RxBuffer[RxIndex++] = c;
    } else if (RxIndex > 0 && RxIndex < RX_BUF_SIZE - 1) {
        RxBuffer[RxIndex++] = c;
        if (c == '#') {
            RxBuffer[RxIndex] = '\0';
            RX_Command_Ready = 1;
            RxIndex = 0;
        }
    }

    if (c == 'a') txflg = 1;
}

