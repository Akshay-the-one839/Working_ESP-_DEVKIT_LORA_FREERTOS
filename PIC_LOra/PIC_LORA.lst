.................... // ------------------------------------------------------------------ 
.................... // Timer1 setup 
.................... // At 20 MHz / 4 = 5 MHz, prescaler /8 = 625 kHz tick. 
.................... // Reload 34286 -> 31250 ticks * 1.6 us = 50 ms per overflow. 
.................... // 20 overflows = 1 second. 
.................... // ------------------------------------------------------------------ 
.................... void setup_timer1_for_1s_interrupt(void) 
.................... { 
....................     setup_timer_1(T1_INTERNAL | T1_DIV_BY_8); 
*
