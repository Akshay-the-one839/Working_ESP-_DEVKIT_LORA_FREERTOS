0428:  MOVLW  85
042A:  MOVWF  FCF
042C:  MOVLW  EE
042E:  MOVWF  FCE
....................     enable_interrupts(INT_TIMER1); 
0430:  BSF    F9D.0
0432:  GOTO   16FA (RETURN)
.................... } 
