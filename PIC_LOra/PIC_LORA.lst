046A:  MOVLW  01
046C:  MOVWF  01
046E:  RETURN 0
.................... } 
....................  
.................... // ------------------------------------------------------------------ 
.................... // save_valve_states_to_eeprom() 
.................... // ------------------------------------------------------------------ 
